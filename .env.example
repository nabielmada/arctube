# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Nuxt (prefix for frontend access)
NUXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Circle ────────────────────────────────────────────────────
CIRCLE_API_KEY=TEST_API_KEY:xxxx
CIRCLE_WALLET_SET_ID=xxxx
CIRCLE_ENVIRONMENT=sandbox

# ─── Arc Network ────────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_USDC_CONTRACT=0x3600000000000000000000000000000000000000
NUXT_PUBLIC_ARC_EXPLORER=https://testnet.arcscan.app

# ─── App ────────────────────────────────────────────────────────
API_PORT=3001
NUXT_PUBLIC_API_BASE=http://localhost:3001
JWT_SECRET=not_needed_supabase_handles_auth

# ─── Payment Config ─────────────────────────────────────────────
NUXT_PUBLIC_PRICE_PER_SECOND=0.001
NUXT_PUBLIC_FREE_TEASER_SECONDS=10
HEARTBEAT_INTERVAL_MS=1000
